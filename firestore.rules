rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'crwom01@gmail.com' || 
        request.auth.token.email == 'leps.vespertina.epja@gmail.com' ||
        request.auth.token.email == 'jav.arayamolina@gmail.com'
      );
    }

    function isOwner(data) {
      return isSignedIn() && data.authorId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Common read for all public collections
    match /projects/{id} {
      allow read: if true;
      allow create: if isValidId(id) && request.resource.data.approved == false;
      allow update: if isAdmin() || (isOwner(resource.data) && request.resource.data.approved == resource.data.approved);
      allow delete: if isAdmin() || isOwner(resource.data);
    }

    match /studentWorks/{id} {
      allow read: if true;
      allow create: if isValidId(id) && request.resource.data.approved == false;
      allow update: if isAdmin() || (isOwner(resource.data) && request.resource.data.approved == resource.data.approved);
      allow delete: if isAdmin() || isOwner(resource.data);
    }

    match /materials/{id} {
      allow read: if true;
      allow create: if isValidId(id) && request.resource.data.approved == false;
      allow update: if isAdmin() || (isOwner(resource.data) && request.resource.data.approved == resource.data.approved);
      allow delete: if isAdmin() || isOwner(resource.data);
    }

    match /activities/{id} {
      allow read: if true;
      allow create: if isValidId(id) && request.resource.data.approved == false;
      allow update: if isAdmin() || (isOwner(resource.data) && request.resource.data.approved == resource.data.approved);
      allow delete: if isAdmin() || isOwner(resource.data);
    }

    match /testimonials/{id} {
      allow read: if true;
      allow create: if isValidId(id) && request.resource.data.approved == false;
      allow update: if isAdmin() || (isOwner(resource.data) && request.resource.data.approved == resource.data.approved);
      allow delete: if isAdmin() || isOwner(resource.data);
    }

    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for anything else
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
